{
  "name": "@disc-foundation/api",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsup src/server.ts --format esm --platform node --target node20 --out-dir dist --clean --splitting false --external @prisma/client --external fastify --external zod",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@disc-foundation/application": "workspace:*",
    "@disc-foundation/infrastructure": "workspace:*",
    "fastify": "^5.6.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "tsup": "^8.5.0"
  },
  "exports": {
    ".": {
      "import": "./dist/server.js"
    }
  }
}
