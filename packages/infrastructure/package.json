{
  "name": "@disc-foundation/infrastructure",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:db:push": "prisma db push --schema prisma/schema.prisma --accept-data-loss --skip-generate",
    "prisma:sync": "pnpm prisma:db:push && pnpm prisma:generate"
  },
  "dependencies": {
    "@disc-foundation/application": "workspace:*",
    "@disc-foundation/domain": "workspace:*",
    "@disc-foundation/shared": "workspace:*",
    "@prisma/client": "^6.16.2"
  },
  "devDependencies": {
    "prisma": "^6.16.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
